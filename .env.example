# ==============================================================================
# Hiqonis Environment Variables Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# --- Project Identity ---
PROJECT_NAME=Hiqonis
API_V1_STR=/api/v1

# --- Core Databases ---
# Standard SQLAlchemy asyncpg driver for PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password123@localhost:5432/hiqonis

# Redis Cache and Event Task Broker
REDIS_URL=redis://localhost:6379/0

# --- Security & JWT Session ---
# IMPORTANT: Generate a strong random key in production (e.g. using `openssl rand -hex 32`)
JWT_SECRET=supersecretjwtkeythatissecretdontshare
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- LiteLLM Multi-Provider Proxy Gateway ---
# LiteLLM allows swapping models instantly without code modification
LITELLM_URL=http://localhost:4000

# --- AI Providers Keys (Used by LiteLLM / RAG) ---
# Fill in keys for the providers you plan to use:
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Omni-Channel messaging adapters (Meta) ---
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_token_here

# --- Outbound Integrations and Payment Gateways (Midtrans SNAP) ---
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_IS_PRODUCTION=false

# --- Outbound Telephony Voice AI (Vapi.ai) ---
VAPI_API_KEY=your_vapi_api_key_here

# --- E-Commerce Marketplace Adapters (Shopee & Tokopedia) ---
SHOPEE_PARTNER_ID=your_shopee_partner_id_here
SHOPEE_PARTNER_KEY=your_shopee_partner_key_here
TOKOPEDIA_CLIENT_ID=your_tokopedia_client_id_here
TOKOPEDIA_CLIENT_SECRET=your_tokopedia_client_secret_here

# --- Email Notifications Service (Resend) ---
RESEND_API_KEY=your_resend_api_key_here
