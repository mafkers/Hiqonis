# ==============================================================================
# Hiqonis Standard Git Ignore Configuration
# ==============================================================================

# --- Operating System Caches & Diagnostics ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDEs and Editors ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.project
.classpath
.settings/

# --- Node.js & Web Frontend (Next.js / Tailwind) ---
node_modules/
.next/
out/
dist/
build/
.pnpm-debug.log*
.eslintcache
.turbo/

# --- Python Ecosystem (FastAPI / uv / pytest) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pylint.d/
.ipynb_checkpoints/
.coverage
htmlcov/
.tox/
.nox/
pip-log.txt
pip-delete-this-directory.txt

# --- Logs, Databases & Backups ---
*.log
*.sqlite
*.sqlite3
*.db
*.bak
*.sql
*.dump

# --- Environment Variables & Secrets (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.cert
*.crt
secrets.json
service-account.json

# --- App Storage & Uploads (Exclude dynamic media / database dumps) ---
storage/
!storage/.gitkeep
